# Root .htaccess — Gerçek dosya/klasör varsa direkt sun, yoksa public/'a yönlendir
RewriteEngine On

# HTTPS yönlendirme (production) — burada yapılmalı, döngü oluşmaması için
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Sadece gerçek DOSYALAR (uploads, vb.) bypass edilsin
# Klasörler bypass edilmemeli — kök dizin de dahil, aksi halde / 403 verir
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Her şey public/'a yönlendir
RewriteRule ^(.*)$ public/$1 [L]
