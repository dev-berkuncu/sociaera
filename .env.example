# Environment (development/production)
APP_ENV=production
APP_TIMEZONE=Europe/Istanbul

# Database Configuration
DB_HOST=localhost
DB_NAME=sociaera_db
DB_USER=root
DB_PASS=secret
DB_CHARSET=utf8mb4

# Site Configuration
BASE_URL=https://sociaera.online

# Session Configuration
SESSION_LIFETIME=86400

# OAuth Configuration (GTA World TR UCP)
OAUTH_CLIENT_ID=your_client_id
OAUTH_CLIENT_SECRET=your_client_secret
OAUTH_REDIRECT_URI=https://sociaera.online/oauth-callback

# Fleeca Bank API
FLEECA_AUTH_KEY=your_fleeca_auth_key
FLEECA_GATEWAY_ID=your_fleeca_gateway_id
FLEECA_CALLBACK_URL=https://sociaera.online/api/fleeca-callback
